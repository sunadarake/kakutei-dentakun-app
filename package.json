{
  "name": "kakutei-dentakun",
  "version": "1.0.0",
  "main": "src/main/index.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "build": "vite build && electron-builder"
  },
  "keywords": [],
  "author": {
    "name": "sunadarake",
    "email": "your@email.com"
  },
  "license": "ISC",
  "description": "",
  "build": {
    "appId": "com.kakutei.dentakun",
    "productName": "確定申告足し算くん",
    "icon": "icons/plus.png",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/renderer/**/*",
      "src/main/**/*",
      "src/preload/**/*",
      "icons/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icons/plus.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "icons/plus.png",
      "category": "Office"
    }
  },
  "devDependencies": {
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "concurrently": "^9.2.1",
    "vite": "^7.3.1"
  }
}
